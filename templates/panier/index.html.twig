{% extends 'base.html.twig' %}
{% block title %}Mon Panier — SymHome{% endblock %}

{% block body %}

{# NAVBAR #}
<nav style="background:#1a1a2e; padding:15px 40px; display:flex;
            justify-content:space-between; align-items:center;">
    <a href="{{ path('app_meubles') }}"
       style="color:#c9a96e; font-size:1.5rem; font-weight:bold; text-decoration:none;">
        🏠 SymHome
    </a>
    <div style="color:white;">
        Bonjour <strong style="color:#c9a96e;">{{ app.user.prenom }}</strong> |
        <a href="{{ path('app_logout') }}" style="color:#c9a96e;">Se déconnecter</a>
    </div>
</nav>

<div style="background:#f8f5f0; min-height:80vh; padding:40px;">
    <div style="max-width:900px; margin:0 auto;">

        <h1 style="color:#1a1a2e; margin-bottom:30px;">🛒 Mon Panier</h1>

        {# MESSAGES FLASH #}
        {% for message in app.flashes('success') %}
            <div style="background:#e8f8e8; color:#27ae60; padding:12px 16px;
                        border-radius:8px; margin-bottom:20px;">{{ message }}</div>
        {% endfor %}

        {% if panierData is empty %}
            <div style="text-align:center; padding:60px; background:white;
                        border-radius:16px; box-shadow:0 4px 15px rgba(0,0,0,0.08);">
                <p style="font-size:3rem;">🛒</p>
                <p style="font-size:1.2rem; color:#888;">Votre panier est vide</p>
                <a href="{{ path('app_meubles') }}"
                   style="display:inline-block; margin-top:20px; padding:12px 25px;
                          background:#c9a96e; color:white; border-radius:10px;
                          text-decoration:none; font-weight:bold;">
                    Voir les meubles
                </a>
            </div>
        {% else %}

            {# LISTE DES ARTICLES #}
            {% for item in panierData %}
            <div style="background:white; border-radius:16px; padding:20px;
                        margin-bottom:15px; display:flex; align-items:center;
                        gap:20px; box-shadow:0 4px 15px rgba(0,0,0,0.08);">

                {# IMAGE #}
                {% if item.meuble.image %}
                    <img src="{{ item.meuble.image }}" alt="{{ item.meuble.nom }}"
                         style="width:100px; height:100px; object-fit:cover; border-radius:10px;">
                {% else %}
                    <div style="width:100px; height:100px; background:#f0ece4;
                                display:flex; align-items:center; justify-content:center;
                                border-radius:10px; font-size:2rem;">🛋️</div>
                {% endif %}

                {# INFOS #}
                <div style="flex:1;">
                    <h3 style="color:#1a1a2e; margin:0 0 5px;">{{ item.meuble.nom }}</h3>
                    <p style="color:#c9a96e; font-weight:bold;">
                        {{ item.meuble.prix }} TND / unité
                    </p>
                </div>

                {# QUANTITE #}
<form method="post"
      action="{{ path('app_panier_modifier', {'id': item.meuble.id}) }}"
      style="display:flex; align-items:center; gap:10px;">
    <input type="number" name="quantite" value="{{ item.quantite }}"
           min="1" max="{{ item.meuble.stock }}"
           onchange="this.form.submit()"
           style="width:70px; padding:8px; border:2px solid #ddd;
                  border-radius:8px; text-align:center; font-size:1rem;">
</form>

                {# SOUS TOTAL #}
                <div style="min-width:100px; text-align:right;">
                    <span style="color:#c9a96e; font-size:1.2rem; font-weight:bold;">
                    {{ (item.meuble.prix * item.quantite)|number_format(2, '.', ' ') }} TND
                    </span>
                </div>

                {# SUPPRIMER #}
                <a href="{{ path('app_panier_supprimer', {'id': item.meuble.id}) }}"
                   style="color:#e74c3c; font-size:1.3rem; text-decoration:none;"
                   onclick="return confirm('Supprimer cet article ?')">❌</a>
            </div>
            {% endfor %}

            {# TOTAL + ACTIONS #}
            <div style="background:white; border-radius:16px; padding:25px;
                        box-shadow:0 4px 15px rgba(0,0,0,0.08);">
                <div style="display:flex; justify-content:space-between;
                            align-items:center; margin-bottom:20px;">
                    <span style="font-size:1.3rem; font-weight:bold; color:#1a1a2e;">
                        Total :
                    </span>
                    <span style="font-size:1.8rem; font-weight:bold; color:#c9a96e;">
                       {{ total|number_format(2, '.', ' ') }} TND
                    </span>
                </div>

                <div style="display:flex; gap:15px; flex-wrap:wrap;">
                    <a href="{{ path('app_meubles') }}"
                       style="flex:1; padding:14px; background:#eee; color:#333;
                              border-radius:10px; text-align:center; text-decoration:none;
                              font-weight:bold;">
                        ← Continuer mes achats
                    </a>
                    <a href="{{ path('app_panier_vider') }}"
                       style="padding:14px 20px; background:#e74c3c; color:white;
                              border-radius:10px; text-decoration:none; font-weight:bold;"
                       onclick="return confirm('Vider le panier ?')">
                        🗑️ Vider
                    </a>
                    <a href="#"
                       style="flex:1; padding:14px; background:#c9a96e; color:white;
                              border-radius:10px; text-align:center; text-decoration:none;
                              font-weight:bold;">
                        ✅ Commander
                    </a>
                </div>
            </div>

        {% endif %}
    </div>
</div>

{% endblock %}