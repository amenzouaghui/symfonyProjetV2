{% extends 'admin/base.html.twig' %}
{% block title %}Meuble index{% endblock %}

{% block body %}
    <h1>Meuble</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Description</th>
                <th>Prix</th>
                <th>Stock</th>
                <th>IsActive</th>
                <th>CreatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for meuble in meubles %}
            <tr>
                <td>{{ meuble.id }}</td>
                <td>{{ meuble.nom }}</td>
                <td>{{ meuble.description }}</td>
                <td>{{ meuble.prix }}</td>
                <td>{{ meuble.stock }}</td>
                <td>{{ meuble.isActive ? 'Yes' : 'No' }}</td>
                <td>{{ meuble.createdAt ? meuble.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_admin_meuble_show', {'id': meuble.id}) }}">show</a>
                    <a href="{{ path('app_admin_meuble_edit', {'id': meuble.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin_meuble_new') }}">Create new</a>
{% endblock %}
